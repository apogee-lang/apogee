{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Apogee",
  "scopeName": "source.apogee",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#constraint-expression" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#constants" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.apogee",
          "match": "//.*$"
        },
        {
          "name": "comment.block.apogee",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.intent.apogee",
          "begin": "(@intent)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.modifier.annotation.apogee" },
            "2": { "name": "punctuation.paren.open.apogee" }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": { "name": "punctuation.paren.close.apogee" }
          },
          "patterns": [
            {
              "name": "string.quoted.double.intent.apogee",
              "begin": "\"",
              "end": "\"",
              "patterns": [
                {
                  "name": "constant.character.escape.apogee",
                  "match": "\\\\."
                }
              ]
            }
          ]
        },
        {
          "name": "storage.modifier.annotation.apogee",
          "match": "@(intent|pure|async)\\b"
        },
        {
          "name": "storage.modifier.annotation.apogee",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.apogee",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.apogee",
              "match": "\\\\[ntr\\\\\"']"
            },
            {
              "name": "meta.interpolation.apogee",
              "begin": "\\\\\\(",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.apogee" }
              },
              "end": "\\)",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.apogee" }
              },
              "patterns": [
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#numbers" },
                { "include": "#operators" },
                { "include": "#constants" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.apogee",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.apogee",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.apogee",
          "match": "\\b(if|else|for|in|while|match|return)\\b"
        },
        {
          "name": "keyword.declaration.apogee",
          "match": "\\b(fn|type|let)\\b"
        },
        {
          "name": "keyword.other.apogee",
          "match": "\\b(from|where|spawn|import|async|await)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Nullable type suffix",
          "name": "meta.type.nullable.apogee",
          "match": "\\b([A-Z][a-zA-Z0-9]*)(\\?)",
          "captures": {
            "1": { "name": "entity.name.type.apogee" },
            "2": { "name": "keyword.operator.nullable.apogee" }
          }
        },
        {
          "comment": "PascalCase type names",
          "name": "entity.name.type.apogee",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "comment": "Function name after fn keyword",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)",
          "captures": {
            "1": { "name": "keyword.declaration.apogee" },
            "2": { "name": "entity.name.function.apogee" }
          }
        }
      ]
    },
    "type-declaration": {
      "patterns": [
        {
          "comment": "Type name after type keyword",
          "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9]*)",
          "captures": {
            "1": { "name": "keyword.declaration.apogee" },
            "2": { "name": "entity.name.type.definition.apogee" }
          }
        }
      ]
    },
    "constraint-expression": {
      "patterns": [
        {
          "comment": "where constraint clause",
          "match": "\\b(where)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(>=|<=|>|<|==|!=)\\s*",
          "captures": {
            "1": { "name": "keyword.other.apogee" },
            "2": { "name": "variable.parameter.constraint.apogee" },
            "3": { "name": "keyword.operator.comparison.apogee" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.apogee",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.apogee",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.apogee",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.apogee",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.apogee",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.nullable.apogee",
          "match": "\\?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.apogee",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.bracket.apogee",
          "match": "[{}()\\[\\]]"
        },
        {
          "name": "punctuation.accessor.apogee",
          "match": "\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.apogee",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.apogee",
          "match": "\\bnull\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Backtick multi-word identifiers",
          "name": "variable.other.backtick.apogee",
          "match": "`[^`]+`"
        },
        {
          "comment": "Function call",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.apogee" }
          }
        },
        {
          "name": "variable.other.apogee",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
