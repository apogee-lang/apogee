{
  "Function Declaration": {
    "prefix": "fn",
    "body": [
      "@intent(\"${1:describe what this function does}\")",
      "fn ${2:name}(${3:params}) -> ${4:ReturnType} {",
      "  $0",
      "}"
    ],
    "description": "Apogee function with @intent annotation"
  },
  "Function (no intent)": {
    "prefix": "func",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "  $0",
      "}"
    ],
    "description": "Apogee function without annotation"
  },
  "Type Definition": {
    "prefix": "type",
    "body": [
      "type ${1:Name} {",
      "  ${2:field}: ${3:Type}",
      "  $0",
      "}"
    ],
    "description": "Apogee type definition"
  },
  "Type with Constraint": {
    "prefix": "typec",
    "body": [
      "type ${1:Name} {",
      "  ${2:field}: ${3:Int} where ${2:field} ${4:>=} ${5:0}",
      "  $0",
      "}"
    ],
    "description": "Apogee type with constraint field"
  },
  "Spawn Block": {
    "prefix": "spawn",
    "body": [
      "spawn {",
      "  ${1:task1()}",
      "  ${2:task2()}",
      "}"
    ],
    "description": "Concurrent spawn block (structured concurrency)"
  },
  "Query Expression": {
    "prefix": "from",
    "body": [
      "from ${1:collection} where ${2:it.${3:field} ${4:==} ${5:value}}"
    ],
    "description": "Data query expression"
  },
  "Intent Annotation": {
    "prefix": "intent",
    "body": [
      "@intent(\"${1:describe behavior}\")"
    ],
    "description": "@intent annotation"
  },
  "Let Binding": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}"
    ],
    "description": "Variable binding"
  },
  "Let with Type": {
    "prefix": "lett",
    "body": [
      "let ${1:name}: ${2:Type} = ${3:value}"
    ],
    "description": "Variable binding with type annotation"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "  $0",
      "}"
    ],
    "description": "If statement"
  },
  "If-Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "  $2",
      "} else {",
      "  $0",
      "}"
    ],
    "description": "If-else statement"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:collection} {",
      "  $0",
      "}"
    ],
    "description": "For loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "  $0",
      "}"
    ],
    "description": "While loop"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "  ${2:pattern} => ${3:result},",
      "  $0",
      "}"
    ],
    "description": "Match expression"
  },
  "Async Function": {
    "prefix": "afn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "  $0",
      "}"
    ],
    "description": "Async function"
  },
  "Print": {
    "prefix": "pr",
    "body": [
      "print(${1:value})"
    ],
    "description": "Print to stdout"
  }
}
